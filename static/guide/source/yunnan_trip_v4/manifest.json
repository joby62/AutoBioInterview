      "relationship_id": "rId43",
      "source_media_path": "word/media/image37.png",
      "original_name": "image37.png",
      "extracted_name": "image-037.png",
      "relative_path": "./images/image-037.png",
      "paragraph_index": 258,
      "paragraph_text": "",
      "previous_text": "当天就在独克宗古城游玩，后面就是龟山公园，拥有实际上最大的传经筒。",
