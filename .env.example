ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Domain for production Caddy HTTPS reverse proxy.
APP_DOMAIN=your.domain.com

# Optional: local dev exposed port for Caddy.
DEV_HTTP_PORT=5000

# Optional: uvicorn worker count used in docker-compose.prod.yml.
UVICORN_WORKERS=2

# Optional: explicit selectable models shown/accepted by /model-config.
# Keep mini/lite/pro order to match participant speed tiers.
ARK_MODEL_CHOICES=doubao-seed-2-0-mini-260215,doubao-seed-2-0-lite-260215,doubao-seed-2-0-pro-260215

# Initial active models at startup (no automatic fallback retry on failures).
MODEL_ORCH=doubao-seed-2-0-mini-260215
MODEL_WRITE=doubao-seed-2-0-lite-260215

# Legacy aliases (optional): only for compatibility with old env naming.
# ARK_MODEL_DEFAULT mirrors MODEL_ORCH initial value.
# ARK_MODEL_FALLBACK mirrors MODEL_WRITE initial value.
# ARK_MODEL_DEFAULT=doubao-seed-2-0-mini-260215
# ARK_MODEL_FALLBACK=doubao-seed-2-0-lite-260215

DB_PATH=./interviews.db
